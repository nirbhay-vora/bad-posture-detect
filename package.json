{
  "name": "ergovision",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "compile-electron": "tsc -p tsconfig.electron.json",
    "dev": "concurrently -n VITE,ELECTRON -c cyan,yellow \"vite\" \"npm run compile-electron && wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.14",
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.47",
    "tailwindcss": "3.4.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
